# Variables nécessaires à la génération d'images via Azure OpenAI gpt-image-2.
# En production (Coolify), définissez-les directement dans la config de l'app.
# En local, copiez ce fichier en .env et remplissez les valeurs.
AZURE_OPENAI_ENDPOINT=https://YOUR-RESOURCE.cognitiveservices.azure.com
AZURE_OPENAI_DEPLOYMENT=gpt-image-2-...
AZURE_OPENAI_API_VERSION=2025-04-01-preview
AZURE_OPENAI_API_KEY=...

# Optionnel : port du serveur (défaut 8000)
PORT=8000
